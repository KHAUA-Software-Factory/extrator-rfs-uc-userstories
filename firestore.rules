rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasFirebaseAdminClaim() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isBootstrapAdmin() {
      return isSignedIn()
        && request.auth.token.email in ['khauatech@gmail.com'];
    }

    function accessPath() {
      return /databases/$(database)/documents/userAccess/$(request.auth.token.email);
    }

    function hasAccessDoc() {
      return isSignedIn()
        && request.auth.token.email is string
        && exists(accessPath());
    }

    function accessRole() {
      return hasAccessDoc() ? get(accessPath()).data.role : null;
    }

    function hasAdminAccess() {
      return hasFirebaseAdminClaim() || isBootstrapAdmin() || accessRole() == 'admin';
    }

    function hasUserAccess() {
      return accessRole() == 'user';
    }

    function hasAnyAccess() {
      return hasAdminAccess() || hasUserAccess();
    }

    function isAuditLogAuthor() {
      return isSignedIn()
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.actorEmail == request.auth.token.email
        && request.resource.data.source == 'client';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /auditLogs/{logId} {
      // Auditoria append-only. Usuarios autenticados registram eventos; apenas admin pode ler.
      allow create: if hasAnyAccess() && isAuditLogAuthor();
      allow read: if hasAdminAccess();
      allow update, delete: if false;
    }

    match /userAccess/{email} {
      // Admin cadastra/edita/remove usuarios. Cada usuario pode ler apenas seu proprio nivel.
      allow read: if hasAdminAccess() || (isSignedIn() && request.auth.token.email == email);
      allow write: if hasAdminAccess();
    }

    match /users/{uid}/sessions/{sessionId} {
      // Admin ve tudo. User ve/grava somente suas proprias sessoes.
      allow read, write: if hasAdminAccess() || (isOwner(uid) && hasAnyAccess());
    }

    match /{path=**}/sessions/{sessionId} {
      // Necessario para listagem admin via collectionGroup('sessions').
      allow read: if hasAdminAccess();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
