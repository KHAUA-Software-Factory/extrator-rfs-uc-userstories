# Copie para github-secrets.env e preencha. O arquivo github-secrets.env está no .gitignore.

# FTP Locaweb (mesmos nomes dos workflows)
HOST=
USER=
PASS=

# Frontend (Vite / Firebase)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_API_BASE_URL=https://ms-app.khaua.com.br
VITE_BASE_PATH=/

# Backend — chave OpenAI
OPENAI_API_KEY=

# Backend — opcionais (pode apagar a linha se não for usar)
BACKEND_PORT=
BACKEND_HOST=
OPENAI_MODEL=
OPENAI_BASE_URL=
ADMIN_EMAILS=
CORS_ORIGINS=https://ms.khaua.com.br,https://khaua.com.br,https://www.khaua.com.br
JSON_BODY_LIMIT=1mb

# Firebase Admin: caminho absoluto ou relativo à raiz do repo (arquivo local, não commitado).
# Ex.: FIREBASE_SERVICE_ACCOUNT_JSON_FILE=/Users/voce/Downloads/exu-firebase-adminsdk.json
FIREBASE_SERVICE_ACCOUNT_JSON_FILE=
