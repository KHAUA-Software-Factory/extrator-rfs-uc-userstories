PORT=4000
# Opcional. Deixe vazio na maioria das hospedagens.
HOST=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_BASE_URL=https://api.openai.com/v1

# Firebase Admin (recomendado: usar arquivo JSON)
FIREBASE_SERVICE_ACCOUNT_FILE=service-account.json
# Alternativa para hospedagem sem arquivo local: cole o JSON inteiro em uma
# variavel de ambiente chamada FIREBASE_SERVICE_ACCOUNT_JSON.

# Lista de e-mails admin separados por vírgula (case-insensitive)
ADMIN_EMAILS=
