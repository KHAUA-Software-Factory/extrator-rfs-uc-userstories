# Copie este arquivo para .env e preencha sua chave.
OPENAI_API_KEY=sua_chave_aqui

# Modelo usado para extrair requisitos funcionais.
# Voce pode trocar por outro modelo disponivel na sua conta.
OPENAI_MODEL=gpt-5.2

# Endpoint padrao da API OpenAI Responses.
OPENAI_BASE_URL=https://api.openai.com/v1
