<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_PlataformaRF" targetNamespace="http://mestrado.exu/plataforma-requisitos" exporter="Camunda Modeler" exporterVersion="5.46.1" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.21.0">
  <bpmn:collaboration id="Collaboration_PlataformaRF">
    <bpmn:participant id="Participant_Plataforma" name="Plataforma de Engenharia de Requisitos com Apoio de IA" processRef="Process_PlataformaRF" />
    <bpmn:textAnnotation id="TA_LegendaCores">
      <bpmn:text>Cor das raias: amarelo = Stakeholders (decisão humana/validação) | azul = Frontend (Vite+React: formulários, tabelas editáveis, canvas/preview) | cinza = Backend (API/serviços: orquestração e prompts) | verde = API de IA (OpenAI via HTTPS) | roxo = Persistência (Firebase Firestore: sessões em texto)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TA_LegendaInputs">
      <bpmn:text>Input inicial: descrição em texto natural (PT-BR).
Fluxo: IA extrai requisitos funcionais (RFs) → RFs editáveis no frontend (adicionar/remover/editar) → validação → IA gera lista de casos de uso (UCs) → UCs editáveis/validadas → canvas no frontend para diagrama de casos de uso (include/extend) → edição salva como PlantUML (texto) → validação → IA gera User Stories.
Persistência: tudo salvo como TEXTO em sessões no Firebase Firestore. (Sem geração/armazenamento de PDF.)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="A_Leg1" associationDirection="None" sourceRef="TA_LegendaCores" targetRef="TA_LegendaInputs" />
  </bpmn:collaboration>
  <bpmn:process id="Process_PlataformaRF" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Stakeholders" name="Stakeholders (equipe de requisitos)">
        <bpmn:flowNodeRef>Start_Demanda</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Brainstorming</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_BriefOK</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RevisarRFs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_RFsOK</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_AjusteRFs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EditarRFs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReformularDescricao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_BotaoValidarRFs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_BotaoGerarUC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RevisarUCs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_UCsOK</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_AjusteUCs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_BotaoValidarUCs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EditarUCs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VoltarRFs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RevisarDiagramas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_DiagOK</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_BotaoGerarUS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RevisarUS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_USOK</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_AjusteUS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegerarUS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VoltarUCs_AjusteUS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_BotaoBaixarPDF</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DownloadPDF</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Encerrar</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Frontend" name="Frontend (Vite + React)">
        <bpmn:flowNodeRef>Task_PreencherFormulario</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ExibirTabelaRFs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ExibirTabelaUCs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ExibirDiagramaSVG</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ExibirTabelaUS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DisponibilizarDownload</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Backend" name="Backend (API/serviços: orquestração e prompts)">
        <bpmn:flowNodeRef>Task_ReceberDescricao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_UsarIARF</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_ModoSugestoes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_JuncaoRFs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConstruirPromptUS</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ApiIA" name="API de IA (OpenAI)">
        <bpmn:flowNodeRef>Task_OpenAI_RF_Sugestoes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OpenAI_RF_Conservador</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConverterRFparaUC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DetectarRelacoesUML</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OpenAI_US</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Persistencia" name="Persistência (Firebase Firestore: sessões em texto)">
        <bpmn:flowNodeRef>Task_ReceberJSON_RF</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GerarArtefatosUC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReceberJSON_US</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConsolidarPDF</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Demanda" name="Demanda de analise de requisitos">
      <bpmn:outgoing>F01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_Brainstorming" name="Brainstorming da equipe&#10;(consolidar problema, atores e expectativas)">
      <bpmn:incoming>F01</bpmn:incoming>
      <bpmn:incoming>F_LoopBrief</bpmn:incoming>
      <bpmn:outgoing>F02</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_BriefOK" name="Brief consolidado&#10;e pronto para a interface?">
      <bpmn:incoming>F02</bpmn:incoming>
      <bpmn:outgoing>F_LoopBrief</bpmn:outgoing>
      <bpmn:outgoing>F_BriefOK</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_PreencherFormulario" name="Preencher descrição em texto natural&#10;(textarea)">
      <bpmn:incoming>F_BriefOK</bpmn:incoming>
      <bpmn:incoming>F_LoopReformulou</bpmn:incoming>
      <bpmn:outgoing>F03</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ReceberDescricao" name="Receber e armazenar descrição&#10;(Firestore: descriptionText)">
      <bpmn:incoming>F03</bpmn:incoming>
      <bpmn:outgoing>F04</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_UsarIARF" name="Enviar descrição para IA&#10;extrair requisitos funcionais (RFs)">
      <bpmn:incoming>F04</bpmn:incoming>
      <bpmn:outgoing>F_RF_API_Sim</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_ModoSugestoes" name="Chamada de extração de RFs&#10;(backend: /api/extract-requirements)">
      <bpmn:incoming>F_RF_API_Sim</bpmn:incoming>
      <bpmn:outgoing>F_Sug_Sim</bpmn:outgoing>
      <bpmn:outgoing>F_Sug_Nao</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_OpenAI_RF_Sugestoes" name="OpenAI: extrair RFs (texto → RFs)" implementation="##WebService">
      <bpmn:incoming>F_Sug_Sim</bpmn:incoming>
      <bpmn:outgoing>F_OpenAI_RF1</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_OpenAI_RF_Conservador" name="OpenAI: extrair RFs (texto → RFs)" implementation="##WebService">
      <bpmn:incoming>F_Sug_Nao</bpmn:incoming>
      <bpmn:outgoing>F_OpenAI_RF2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_ReceberJSON_RF" name="Receber RFs (JSON)&#10;e persistir na sessão (Firestore)">
      <bpmn:incoming>F_OpenAI_RF1</bpmn:incoming>
      <bpmn:incoming>F_OpenAI_RF2</bpmn:incoming>
      <bpmn:outgoing>F_ParaJuncao</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_JuncaoRFs" name="Junção: RFs disponiveis para revisao">
      <bpmn:incoming>F_ParaJuncao</bpmn:incoming>
      <bpmn:outgoing>F05</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ExibirTabelaRFs" name="Exibir RFs editáveis (tabela)&#10;(adicionar/remover/editar)">
      <bpmn:incoming>F05</bpmn:incoming>
      <bpmn:incoming>F_LoopRFs</bpmn:incoming>
      <bpmn:incoming>F_LoopRFsDoUC</bpmn:incoming>
      <bpmn:outgoing>F06</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_RevisarRFs" name="Stakeholders revisam RFs&#10;(rastreabilidade x brief)">
      <bpmn:incoming>F06</bpmn:incoming>
      <bpmn:outgoing>F07</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_RFsOK" name="RFs validados pelos stakeholders&#10;(gate Etapa 1)?">
      <bpmn:incoming>F07</bpmn:incoming>
      <bpmn:outgoing>F_RFs_Nao</bpmn:outgoing>
      <bpmn:outgoing>F_RFs_Sim</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_AjusteRFs" name="Como corrigir os RFs?">
      <bpmn:incoming>F_RFs_Nao</bpmn:incoming>
      <bpmn:outgoing>F_AjusteEditar</bpmn:outgoing>
      <bpmn:outgoing>F_AjusteReformular</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_EditarRFs" name="Editar RFs inline na tabela&#10;(sem refazer descricao)">
      <bpmn:incoming>F_AjusteEditar</bpmn:incoming>
      <bpmn:outgoing>F_LoopRFs</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ReformularDescricao" name="Reformular brief original&#10;(mudar a string de entrada)">
      <bpmn:incoming>F_AjusteReformular</bpmn:incoming>
      <bpmn:outgoing>F_LoopReformulou</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_BotaoValidarRFs" name="Clicar &#34;Validar requisitos&#34;&#10;(fecha gate Etapa 1)">
      <bpmn:incoming>F_RFs_Sim</bpmn:incoming>
      <bpmn:outgoing>F08</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_BotaoGerarUC" name="Clicar &#34;Gerar casos de uso&#34; (IA)">
      <bpmn:incoming>F08</bpmn:incoming>
      <bpmn:outgoing>F09</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_ConverterRFparaUC" name="OpenAI: gerar lista de casos de uso&#10;(RFs validados → UCs)" implementation="##WebService">
      <bpmn:incoming>F09</bpmn:incoming>
      <bpmn:outgoing>F10</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_DetectarRelacoesUML" name="Preparar diagrama editável&#10;(UCs → canvas + PlantUML base)" implementation="##WebService">
      <bpmn:incoming>F10</bpmn:incoming>
      <bpmn:outgoing>F11</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_ExibirTabelaUCs" name="Exibir UCs editáveis (tabela)&#10;(adicionar/remover/editar)">
      <bpmn:incoming>F11</bpmn:incoming>
      <bpmn:incoming>F_LoopUCs</bpmn:incoming>
      <bpmn:incoming>F_LoopUCsDeUS</bpmn:incoming>
      <bpmn:outgoing>F12</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_GerarArtefatosUC" name="Persistir diagrama editado&#10;(salvar PlantUML em texto no Firestore)">
      <bpmn:incoming>F14</bpmn:incoming>
      <bpmn:outgoing>F15</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_ConstruirPromptUS" name="Montar payload&#10;(PlantUML validado → User Stories)">
      <bpmn:incoming>F18</bpmn:incoming>
      <bpmn:outgoing>F19</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_OpenAI_US" name="OpenAI: gerar User Stories&#10;(a partir do PlantUML validado)" implementation="##WebService">
      <bpmn:incoming>F19</bpmn:incoming>
      <bpmn:incoming>F_LoopUSRegerar</bpmn:incoming>
      <bpmn:outgoing>F20</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_ReceberJSON_US" name="Receber User Stories (JSON)&#10;e persistir na sessão (Firestore)">
      <bpmn:incoming>F20</bpmn:incoming>
      <bpmn:outgoing>F21</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ExibirTabelaUS" name="Exibir tabela de User Stories&#10;com criterios de aceitacao">
      <bpmn:incoming>F21</bpmn:incoming>
      <bpmn:outgoing>F22</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_RevisarUS" name="Stakeholders revisam User Stories&#10;e criterios de aceitacao">
      <bpmn:incoming>F22</bpmn:incoming>
      <bpmn:outgoing>F23</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_USOK" name="User Stories validadas&#10;(gate Etapa 3)?">
      <bpmn:incoming>F23</bpmn:incoming>
      <bpmn:outgoing>F_US_Nao</bpmn:outgoing>
      <bpmn:outgoing>F_US_Sim</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_RegerarUS" name="Solicitar nova rodada na IA&#10;(mesma base de UCs)">
      <bpmn:incoming>F_USAjusteRegerar</bpmn:incoming>
      <bpmn:outgoing>F_LoopUSRegerar</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_VoltarUCs_AjusteUS" name="Voltar a editar UCs&#10;(retoma fluxo da Etapa 2)">
      <bpmn:incoming>F_USAjusteVoltar</bpmn:incoming>
      <bpmn:outgoing>F_LoopUCsDeUS</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_BotaoBaixarPDF" name="Finalizar análise&#10;(salvar sessão)">
      <bpmn:incoming>F_US_Sim</bpmn:incoming>
      <bpmn:outgoing>F24</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_ConsolidarPDF" name="Consolidar e salvar sessão final&#10;(texto: descrição, RFs, UCs, PlantUML, User Stories) no Firestore">
      <bpmn:incoming>F24</bpmn:incoming>
      <bpmn:outgoing>F25</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_DisponibilizarDownload" name="Exibir confirmação de salvamento&#10;(retornar ao dashboard)">
      <bpmn:incoming>F25</bpmn:incoming>
      <bpmn:outgoing>F26</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_DownloadPDF" name="Encerrar iteração">
      <bpmn:incoming>F26</bpmn:incoming>
      <bpmn:outgoing>F27</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_Encerrar" name="Iteracao concluida&#10;(rastreabilidade brief para US)">
      <bpmn:incoming>F27</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_AjusteUCs" name="Como corrigir os UCs?">
      <bpmn:incoming>F_UCs_Nao</bpmn:incoming>
      <bpmn:outgoing>F_UC_Editar</bpmn:outgoing>
      <bpmn:outgoing>F_UC_Voltar</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_RevisarUCs" name="Stakeholders revisam UCs&#10;(coerencia, atores, fluxos)">
      <bpmn:incoming>F12</bpmn:incoming>
      <bpmn:outgoing>F13</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_UCsOK" name="UCs validados pelos stakeholders&#10;(gate Etapa 2)?">
      <bpmn:incoming>F13</bpmn:incoming>
      <bpmn:outgoing>F_UCs_Nao</bpmn:outgoing>
      <bpmn:outgoing>F_UCs_Sim</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_BotaoValidarUCs" name="Clicar &#34;Validar casos de uso&#34;&#10;(fecha gate Etapa 2)">
      <bpmn:incoming>F_UCs_Sim</bpmn:incoming>
      <bpmn:outgoing>F14</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_EditarUCs" name="Editar UCs inline&#10;(salvar reexporta artefatos)">
      <bpmn:incoming>F_UC_Editar</bpmn:incoming>
      <bpmn:incoming>F_Diag_Nao</bpmn:incoming>
      <bpmn:outgoing>F_LoopUCs</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ExibirDiagramaSVG" name="Canvas/preview do diagrama&#10;(React Flow + SVG PlantUML)">
      <bpmn:incoming>F15</bpmn:incoming>
      <bpmn:outgoing>F16</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_RevisarDiagramas" name="Revisar diagrama no canvas&#10;(include/extend + relações)">
      <bpmn:incoming>F16</bpmn:incoming>
      <bpmn:outgoing>F17</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_DiagOK" name="Diagrama aprovado?">
      <bpmn:incoming>F17</bpmn:incoming>
      <bpmn:outgoing>F_Diag_Nao</bpmn:outgoing>
      <bpmn:outgoing>F_Diag_Sim</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_BotaoGerarUS" name="Clicar &#34;Gerar User Stories&#34; (IA)">
      <bpmn:incoming>F_Diag_Sim</bpmn:incoming>
      <bpmn:outgoing>F18</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_VoltarRFs" name="Voltar a revisar RFs&#10;(corrigir antes dos UCs)">
      <bpmn:incoming>F_UC_Voltar</bpmn:incoming>
      <bpmn:outgoing>F_LoopRFsDoUC</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_AjusteUS" name="Como corrigir as User Stories?">
      <bpmn:incoming>F_US_Nao</bpmn:incoming>
      <bpmn:outgoing>F_USAjusteRegerar</bpmn:outgoing>
      <bpmn:outgoing>F_USAjusteVoltar</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="F01" sourceRef="Start_Demanda" targetRef="Task_Brainstorming" />
    <bpmn:sequenceFlow id="F_LoopBrief" name="Nao - refinar brief" sourceRef="GW_BriefOK" targetRef="Task_Brainstorming" />
    <bpmn:sequenceFlow id="F02" sourceRef="Task_Brainstorming" targetRef="GW_BriefOK" />
    <bpmn:sequenceFlow id="F_BriefOK" name="Sim" sourceRef="GW_BriefOK" targetRef="Task_PreencherFormulario" />
    <bpmn:sequenceFlow id="F_LoopReformulou" sourceRef="Task_ReformularDescricao" targetRef="Task_PreencherFormulario" />
    <bpmn:sequenceFlow id="F03" sourceRef="Task_PreencherFormulario" targetRef="Task_ReceberDescricao" />
    <bpmn:sequenceFlow id="F04" sourceRef="Task_ReceberDescricao" targetRef="GW_UsarIARF" />
    <bpmn:sequenceFlow id="F_RF_API_Sim" name="Sim - usar OpenAI" sourceRef="GW_UsarIARF" targetRef="GW_ModoSugestoes" />
    <bpmn:sequenceFlow id="F_Sug_Sim" name="Sim - com sugestoes" sourceRef="GW_ModoSugestoes" targetRef="Task_OpenAI_RF_Sugestoes" />
    <bpmn:sequenceFlow id="F_Sug_Nao" name="Nao - so explicito" sourceRef="GW_ModoSugestoes" targetRef="Task_OpenAI_RF_Conservador" />
    <bpmn:sequenceFlow id="F_OpenAI_RF1" sourceRef="Task_OpenAI_RF_Sugestoes" targetRef="Task_ReceberJSON_RF" />
    <bpmn:sequenceFlow id="F_OpenAI_RF2" sourceRef="Task_OpenAI_RF_Conservador" targetRef="Task_ReceberJSON_RF" />
    <bpmn:sequenceFlow id="F_ParaJuncao" sourceRef="Task_ReceberJSON_RF" targetRef="GW_JuncaoRFs" />
    <bpmn:sequenceFlow id="F05" sourceRef="GW_JuncaoRFs" targetRef="Task_ExibirTabelaRFs" />
