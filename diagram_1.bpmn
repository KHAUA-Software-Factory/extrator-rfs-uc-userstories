      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_RevisarUCs_di" bpmnElement="Activity_RevisarUCs">
        <dc:Bounds x="1860" y="90" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_UC_Aprovados_di" bpmnElement="Gateway_UC_Aprovados" isMarkerVisible="true">
        <dc:Bounds x="2135" y="825" width="50" height="50" />
