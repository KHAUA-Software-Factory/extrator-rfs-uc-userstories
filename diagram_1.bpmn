        <dc:Bounds x="280" y="90" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_ExtrairRFsIA_di" bpmnElement="Activity_ExtrairRFsIA">
        <dc:Bounds x="500" y="270" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_ExibirTabelaRF_di" bpmnElement="Activity_ExibirTabelaRF">
        <dc:Bounds x="720" y="450" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_RF_Aprovados_di" bpmnElement="Gateway_RF_Aprovados" isMarkerVisible="true">
        <dc:Bounds x="955" y="465" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="940" y="425" width="80" height="27" />
