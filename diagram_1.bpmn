<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_PlataformaRF" targetNamespace="http://mestrado.exu/plataforma-requisitos" exporter="Camunda Modeler" exporterVersion="5.46.1" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.21.0">
  <bpmn:collaboration id="Collaboration_PlataformaRF">
    <bpmn:participant id="Participant_Plataforma" name="Plataforma de Engenharia de Requisitos com Apoio de IA" processRef="Process_PlataformaRF" />
    <bpmn:textAnnotation id="TA_Legenda">
      <bpmn:text>Fluxo alinhado ao web_gui.py / CLI: cada decisao passa por gateway XOR. OpenAI e chamado apenas nos ramos &#34;Sim&#34; correspondentes.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TA_Artefatos">
      <bpmn:text>Artefatos: RF (json, md) | UC (md, csv, txt, svg, puml, pdf parcial) | US (json, md) | relatorio_completo.pdf</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="A_Start_Leg" associationDirection="None" sourceRef="Start_Inicio" targetRef="TA_Legenda" />
    <bpmn:association id="A_TA_Artef" associationDirection="None" sourceRef="TA_Legenda" targetRef="TA_Artefatos" />
    <bpmn:association id="A_DO_Texto" associationDirection="None" sourceRef="Task_RegistrarDescricao" targetRef="DORef_Texto" />
    <bpmn:association id="A_DO_RF1" associationDirection="None" sourceRef="Task_OpenAI_RF_Sugestoes" targetRef="DORef_RFJson" />
    <bpmn:association id="A_DO_RF2" associationDirection="None" sourceRef="Task_OpenAI_RF_Conservador" targetRef="DORef_RFJson" />
    <bpmn:association id="A_DO_Manual" associationDirection="None" sourceRef="Task_RF_Manual" targetRef="DORef_RFJson" />
    <bpmn:association id="A_DO_UC" associationDirection="None" sourceRef="Task_GerarArtefatos" targetRef="DORef_UCPack" />
    <bpmn:association id="A_DO_US" associationDirection="None" sourceRef="Task_OpenAI_US" targetRef="DORef_USPack" />
    <bpmn:association id="A_DO_PDF" associationDirection="None" sourceRef="Task_ExportarConsolidado" targetRef="DORef_PDF" />
  </bpmn:collaboration>
  <bpmn:process id="Process_PlataformaRF" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Equipe" name="Equipe de requisitos / workshop">
        <bpmn:flowNodeRef>Start_Inicio</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Brainstorming</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_BriefConsolidado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RF_Manual</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EditarRF</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EditarUC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_BaixarEntrega</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Fim</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_App" name="Aplicacao web (orquestrador)">
        <bpmn:flowNodeRef>Task_RegistrarDescricao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_UsarAPI_OpenAI_RF</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_ModoSugestoesIA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_DispararGeracaoUC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_UsarAPI_OpenAI_US</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_ConfirmarDownloadPDF</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_OpenAI" name="Integracao OpenAI (HTTPS API)">
        <bpmn:flowNodeRef>Task_OpenAI_RF_Sugestoes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OpenAI_RF_Conservador</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OpenAI_US</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ValRF" name="Validacao humana - RFs">
        <bpmn:flowNodeRef>GW_JuncaoPosExtracao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ExibirTabelaRF</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_RF_ValidadosGerarUC</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_MotorUC" name="Motor casos de uso (regras deterministicas)">
        <bpmn:flowNodeRef>Task_ConverterRFparaUC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DetectarRelacoesUML</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Export" name="Exportacao artefatos e PDF">
        <bpmn:flowNodeRef>Task_GerarArtefatos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ExportarConsolidado</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ValUC" name="Validacao humana - UCs">
        <bpmn:flowNodeRef>Task_RevisarUC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_UC_ValidadosGerarUS</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:dataObject id="DO_Texto" name="Descricao / brief (linguagem natural)" />
    <bpmn:dataObject id="DO_RF" name="requisitos_funcionais.json / .md" />
    <bpmn:dataObject id="DO_UC" name="Pacote UC + diagramas + pdf parcial" />
    <bpmn:dataObject id="DO_US" name="user_stories.json / .md" />
    <bpmn:dataObject id="DO_PDF" name="relatorio_completo.pdf" />
    <bpmn:dataObjectReference id="DORef_Texto" dataObjectRef="DO_Texto" />
    <bpmn:dataObjectReference id="DORef_RFJson" dataObjectRef="DO_RF" />
    <bpmn:dataObjectReference id="DORef_UCPack" dataObjectRef="DO_UC" />
    <bpmn:dataObjectReference id="DORef_USPack" dataObjectRef="DO_US" />
    <bpmn:dataObjectReference id="DORef_PDF" dataObjectRef="DO_PDF" />
    <bpmn:startEvent id="Start_Inicio" name="Demanda de analise">
      <bpmn:outgoing>F01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_Brainstorming" name="Workshop / brainstorming da equipe&#10;consolidar problema e expectativas">
      <bpmn:incoming>F01</bpmn:incoming>
      <bpmn:incoming>F_LoopBrief</bpmn:incoming>
      <bpmn:outgoing>F02</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_BriefConsolidado" name="Brief da equipe aceito para formalizar em texto?">
      <bpmn:incoming>F02</bpmn:incoming>
      <bpmn:outgoing>F_BriefSim</bpmn:outgoing>
      <bpmn:outgoing>F_LoopBrief</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_RegistrarDescricao" name="Registrar descricao no sistema&#10;(textarea + checkbox futuros)">
      <bpmn:incoming>F_BriefSim</bpmn:incoming>
      <bpmn:outgoing>F03</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_UsarAPI_OpenAI_RF" name="Utilizar API OpenAI para extrair lista inicial de RFs?">
      <bpmn:incoming>F03</bpmn:incoming>
      <bpmn:outgoing>F_API_RF_Sim</bpmn:outgoing>
      <bpmn:outgoing>F_API_RF_Nao</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_ModoSugestoesIA" name="Incluir sugestoes inferidas pela IA&#10;(modo proativo / extras)?">
      <bpmn:incoming>F_API_RF_Sim</bpmn:incoming>
      <bpmn:outgoing>F_SugSim</bpmn:outgoing>
      <bpmn:outgoing>F_SugNao</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_OpenAI_RF_Sugestoes" name="POST OpenAI: extrair RFs&#10;(suggest_extras=true)" implementation="##WebService">
      <bpmn:incoming>F_SugSim</bpmn:incoming>
      <bpmn:outgoing>F_ToJoinA</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_OpenAI_RF_Conservador" name="POST OpenAI: extrair RFs&#10;(conservador / explicito)" implementation="##WebService">
      <bpmn:incoming>F_SugNao</bpmn:incoming>
      <bpmn:outgoing>F_ToJoinB</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_RF_Manual" name="Cadastrar RFs manualmente&#10;(sem chamada OpenAI neste ramo)">
      <bpmn:incoming>F_API_RF_Nao</bpmn:incoming>
      <bpmn:outgoing>F_ToJoinC</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_JuncaoPosExtracao" name="RFs disponiveis para revisao&#10;(junção dos tres ramos)">
      <bpmn:incoming>F_ToJoinA</bpmn:incoming>
      <bpmn:incoming>F_ToJoinB</bpmn:incoming>
      <bpmn:incoming>F_ToJoinC</bpmn:incoming>
      <bpmn:outgoing>F04</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ExibirTabelaRF" name="Exibir e editar tabela de RFs&#10;(incluir / excluir linhas)">
      <bpmn:incoming>F04</bpmn:incoming>
      <bpmn:incoming>F_LoopRF</bpmn:incoming>
      <bpmn:incoming>F_UC_Aguardar</bpmn:incoming>
      <bpmn:outgoing>F05</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_RF_ValidadosGerarUC" name="RFs validados&#10;(gate Etapa 1) para liberar geracao de UC?">
      <bpmn:incoming>F05</bpmn:incoming>
      <bpmn:outgoing>F_RF_NaoRevisar</bpmn:outgoing>
      <bpmn:outgoing>F_RF_Sim</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_EditarRF" name="Ajustar RFs&#10;e re-submeter validacao">
      <bpmn:incoming>F_RF_NaoRevisar</bpmn:incoming>
      <bpmn:outgoing>F_LoopRF</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_DispararGeracaoUC" name="Executar geracao de casos de uso&#10;a partir dos RFs aprovados?">
      <bpmn:incoming>F_RF_Sim</bpmn:incoming>
      <bpmn:outgoing>F_UC_Go</bpmn:outgoing>
      <bpmn:outgoing>F_UC_Aguardar</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_ConverterRFparaUC" name="Converter RFs aprovados em UCs">
      <bpmn:incoming>F_UC_Go</bpmn:incoming>
      <bpmn:outgoing>F06</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_DetectarRelacoesUML" name="Detectar relacoes include / extend">
      <bpmn:incoming>F06</bpmn:incoming>
      <bpmn:outgoing>F07</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_GerarArtefatos" name="Gerar MD, CSV, TXT, SVG, PlantUML, PDF parcial">
      <bpmn:incoming>F07</bpmn:incoming>
      <bpmn:outgoing>F08</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_RevisarUC" name="Revisar UCs na tabela editavel&#10;(salvar / adicionar / remover)">
      <bpmn:incoming>F08</bpmn:incoming>
      <bpmn:incoming>F_LoopUC</bpmn:incoming>
      <bpmn:outgoing>F09</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_UC_ValidadosGerarUS" name="UCs validados&#10;(gate Etapa 2) para liberar User Stories?">
      <bpmn:incoming>F09</bpmn:incoming>
      <bpmn:outgoing>F_UC_Nao</bpmn:outgoing>
      <bpmn:outgoing>F_UC_Sim</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_EditarUC" name="Editar UCs e salvar&#10;(regenera artefatos)">
      <bpmn:incoming>F_UC_Nao</bpmn:incoming>
      <bpmn:outgoing>F_LoopUC</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_UsarAPI_OpenAI_US" name="Utilizar API OpenAI para gerar User Stories?">
      <bpmn:incoming>F_UC_Sim</bpmn:incoming>
      <bpmn:outgoing>F_US_API_Sim</bpmn:outgoing>
      <bpmn:outgoing>F_US_API_Nao</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_OpenAI_US" name="POST OpenAI: gerar User Stories&#10;(Mike Cohn + Gherkin)" implementation="##WebService">
      <bpmn:incoming>F_US_API_Sim</bpmn:incoming>
      <bpmn:outgoing>F_ToExportMerge_Sim</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_JuncaoPreExport" name="Junção: seguir para consolidacao&#10;(com ou sem US por IA)">
      <bpmn:incoming>F_ToExportMerge_Sim</bpmn:incoming>
      <bpmn:incoming>F_US_API_Nao</bpmn:incoming>
      <bpmn:outgoing>F_ToExport</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_ExportarConsolidado" name="Consolidar PDF completo e artefatos">
      <bpmn:incoming>F_ToExport</bpmn:incoming>
      <bpmn:outgoing>F10</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_ConfirmarDownloadPDF" name="Registrar entrega / baixar PDF agora?">
      <bpmn:incoming>F10</bpmn:incoming>
      <bpmn:outgoing>F_DL_Sim</bpmn:outgoing>
      <bpmn:outgoing>F_DL_Nao</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_BaixarEntrega" name="Baixar PDF e conferir pacote">
      <bpmn:incoming>F_DL_Sim</bpmn:incoming>
      <bpmn:outgoing>F11</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_Fim" name="Encerramento da iteracao">
      <bpmn:incoming>F11</bpmn:incoming>
      <bpmn:incoming>F_DL_Nao</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F01" sourceRef="Start_Inicio" targetRef="Task_Brainstorming" />
    <bpmn:sequenceFlow id="F02" sourceRef="Task_Brainstorming" targetRef="GW_BriefConsolidado" />
    <bpmn:sequenceFlow id="F_LoopBrief" name="Refinar brief" sourceRef="GW_BriefConsolidado" targetRef="Task_Brainstorming" />
    <bpmn:sequenceFlow id="F_BriefSim" name="Sim" sourceRef="GW_BriefConsolidado" targetRef="Task_RegistrarDescricao" />
    <bpmn:sequenceFlow id="F03" sourceRef="Task_RegistrarDescricao" targetRef="GW_UsarAPI_OpenAI_RF" />
    <bpmn:sequenceFlow id="F_API_RF_Sim" name="Sim" sourceRef="GW_UsarAPI_OpenAI_RF" targetRef="GW_ModoSugestoesIA" />
    <bpmn:sequenceFlow id="F_API_RF_Nao" name="Nao - RF manual" sourceRef="GW_UsarAPI_OpenAI_RF" targetRef="Task_RF_Manual" />
    <bpmn:sequenceFlow id="F_SugSim" name="Com sugestoes IA" sourceRef="GW_ModoSugestoesIA" targetRef="Task_OpenAI_RF_Sugestoes" />
    <bpmn:sequenceFlow id="F_SugNao" name="So texto explicito" sourceRef="GW_ModoSugestoesIA" targetRef="Task_OpenAI_RF_Conservador" />
    <bpmn:sequenceFlow id="F_ToJoinA" sourceRef="Task_OpenAI_RF_Sugestoes" targetRef="GW_JuncaoPosExtracao" />
    <bpmn:sequenceFlow id="F_ToJoinB" sourceRef="Task_OpenAI_RF_Conservador" targetRef="GW_JuncaoPosExtracao" />
    <bpmn:sequenceFlow id="F_ToJoinC" sourceRef="Task_RF_Manual" targetRef="GW_JuncaoPosExtracao" />
    <bpmn:sequenceFlow id="F04" sourceRef="GW_JuncaoPosExtracao" targetRef="Task_ExibirTabelaRF" />
    <bpmn:sequenceFlow id="F05" sourceRef="Task_ExibirTabelaRF" targetRef="GW_RF_ValidadosGerarUC" />
    <bpmn:sequenceFlow id="F_RF_NaoRevisar" name="Nao - editar" sourceRef="GW_RF_ValidadosGerarUC" targetRef="Task_EditarRF" />
    <bpmn:sequenceFlow id="F_LoopRF" sourceRef="Task_EditarRF" targetRef="Task_ExibirTabelaRF" />
    <bpmn:sequenceFlow id="F_RF_Sim" name="Sim - validados" sourceRef="GW_RF_ValidadosGerarUC" targetRef="GW_DispararGeracaoUC" />
    <bpmn:sequenceFlow id="F_UC_Go" name="Sim - gerar UC" sourceRef="GW_DispararGeracaoUC" targetRef="Task_ConverterRFparaUC" />
    <bpmn:sequenceFlow id="F_UC_Aguardar" name="Nao - voltar a revisar RFs" sourceRef="GW_DispararGeracaoUC" targetRef="Task_ExibirTabelaRF" />
    <bpmn:sequenceFlow id="F06" sourceRef="Task_ConverterRFparaUC" targetRef="Task_DetectarRelacoesUML" />
    <bpmn:sequenceFlow id="F07" sourceRef="Task_DetectarRelacoesUML" targetRef="Task_GerarArtefatos" />
    <bpmn:sequenceFlow id="F08" sourceRef="Task_GerarArtefatos" targetRef="Task_RevisarUC" />
    <bpmn:sequenceFlow id="F09" sourceRef="Task_RevisarUC" targetRef="GW_UC_ValidadosGerarUS" />
    <bpmn:sequenceFlow id="F_UC_Nao" name="Nao - editar UC" sourceRef="GW_UC_ValidadosGerarUS" targetRef="Task_EditarUC" />
    <bpmn:sequenceFlow id="F_LoopUC" sourceRef="Task_EditarUC" targetRef="Task_RevisarUC" />
    <bpmn:sequenceFlow id="F_UC_Sim" name="Sim - validados" sourceRef="GW_UC_ValidadosGerarUS" targetRef="GW_UsarAPI_OpenAI_US" />
    <bpmn:sequenceFlow id="F_US_API_Sim" name="Sim" sourceRef="GW_UsarAPI_OpenAI_US" targetRef="Task_OpenAI_US" />
    <bpmn:sequenceFlow id="F_US_API_Nao" name="Nao - pular IA US" sourceRef="GW_UsarAPI_OpenAI_US" targetRef="GW_JuncaoPreExport" />
    <bpmn:sequenceFlow id="F_ToExportMerge_Sim" sourceRef="Task_OpenAI_US" targetRef="GW_JuncaoPreExport" />
    <bpmn:sequenceFlow id="F_ToExport" sourceRef="GW_JuncaoPreExport" targetRef="Task_ExportarConsolidado" />
    <bpmn:sequenceFlow id="F10" sourceRef="Task_ExportarConsolidado" targetRef="GW_ConfirmarDownloadPDF" />
    <bpmn:sequenceFlow id="F_DL_Sim" name="Sim - baixar" sourceRef="GW_ConfirmarDownloadPDF" targetRef="Task_BaixarEntrega" />
    <bpmn:sequenceFlow id="F_DL_Nao" name="Nao - encerrar sem novo download" sourceRef="GW_ConfirmarDownloadPDF" targetRef="End_Fim" />
    <bpmn:sequenceFlow id="F11" sourceRef="Task_BaixarEntrega" targetRef="End_Fim" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_PlataformaRF">
      <bpmndi:BPMNShape id="Participant_di" bpmnElement="Participant_Plataforma" isHorizontal="true">
        <dc:Bounds x="60" y="20" width="4480" height="1090" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Equipe_di" bpmnElement="Lane_Equipe" isHorizontal="true">
        <dc:Bounds x="90" y="20" width="4450" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_App_di" bpmnElement="Lane_App" isHorizontal="true">
        <dc:Bounds x="90" y="160" width="4450" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_OpenAI_di" bpmnElement="Lane_OpenAI" isHorizontal="true">
        <dc:Bounds x="90" y="300" width="4450" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_ValRF_di" bpmnElement="Lane_ValRF" isHorizontal="true">
        <dc:Bounds x="90" y="440" width="4450" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_MotorUC_di" bpmnElement="Lane_MotorUC" isHorizontal="true">
        <dc:Bounds x="90" y="580" width="4450" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Export_di" bpmnElement="Lane_Export" isHorizontal="true">
        <dc:Bounds x="90" y="720" width="4450" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_ValUC_di" bpmnElement="Lane_ValUC" isHorizontal="true">
        <dc:Bounds x="90" y="860" width="4450" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_Inicio_di" bpmnElement="Start_Inicio">
        <dc:Bounds x="130" y="72" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Brainstorming_di" bpmnElement="Task_Brainstorming">
        <dc:Bounds x="210" y="50" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_BriefConsolidado_di" bpmnElement="GW_BriefConsolidado" isMarkerVisible="true">
        <dc:Bounds x="400" y="65" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RegistrarDescricao_di" bpmnElement="Task_RegistrarDescricao">
        <dc:Bounds x="520" y="190" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_UsarAPI_OpenAI_RF_di" bpmnElement="GW_UsarAPI_OpenAI_RF" isMarkerVisible="true">
        <dc:Bounds x="730" y="205" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_ModoSugestoesIA_di" bpmnElement="GW_ModoSugestoesIA" isMarkerVisible="true">
        <dc:Bounds x="860" y="205" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_OpenAI_RF_Sugestoes_di" bpmnElement="Task_OpenAI_RF_Sugestoes">
        <dc:Bounds x="980" y="330" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_OpenAI_RF_Conservador_di" bpmnElement="Task_OpenAI_RF_Conservador">
        <dc:Bounds x="980" y="430" width="170" height="80" />
