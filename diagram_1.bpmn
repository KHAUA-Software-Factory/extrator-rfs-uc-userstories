        <dc:Bounds x="660" y="1240" width="380" height="55" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TextAn_ArtefatosUC_di" bpmnElement="TextAn_ArtefatosUC">
        <dc:Bounds x="1060" y="1240" width="560" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TextAn_ArtefatosUS_di" bpmnElement="TextAn_ArtefatosUS">
        <dc:Bounds x="1640" y="1240" width="420" height="55" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TextAn_Reset_di" bpmnElement="TextAn_Reset">
        <dc:Bounds x="2080" y="1310" width="520" height="55" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_01_di" bpmnElement="Flow_01">
        <di:waypoint x="228" y="130" />
        <di:waypoint x="280" y="130" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_02_di" bpmnElement="Flow_02">
        <di:waypoint x="440" y="130" />
        <di:waypoint x="470" y="130" />
        <di:waypoint x="470" y="310" />
        <di:waypoint x="500" y="310" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_03_di" bpmnElement="Flow_03">
        <di:waypoint x="660" y="310" />
        <di:waypoint x="690" y="310" />
        <di:waypoint x="690" y="490" />
        <di:waypoint x="720" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_04_di" bpmnElement="Flow_04">
        <di:waypoint x="900" y="490" />
        <di:waypoint x="955" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_LoopRF_di" bpmnElement="Flow_LoopRF">
        <di:waypoint x="980" y="465" />
        <di:waypoint x="980" y="220" />
        <di:waypoint x="980" y="130" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_LoopRF_Volta_di" bpmnElement="Flow_LoopRF_Volta">
