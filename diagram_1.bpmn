        <dc:Bounds x="310" y="18" width="36" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="285" y="6" width="86" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataObjectRef_RFJson_di" bpmnElement="DataObjectRef_RFJson">
        <dc:Bounds x="562" y="198" width="36" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataObjectRef_RFmd_di" bpmnElement="DataObjectRef_RFmd">
        <dc:Bounds x="612" y="198" width="36" height="50" />
      </bpmndi:BPMNShape>
