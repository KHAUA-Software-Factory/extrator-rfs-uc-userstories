<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_PlataformaRF" targetNamespace="http://mestrado.exu/plataforma-requisitos" exporter="Camunda Modeler" exporterVersion="5.46.1" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.21.0">
  <bpmn:collaboration id="Collaboration_PlataformaRF">
    <bpmn:participant id="Participant_Plataforma" name="Plataforma de Engenharia de Requisitos com Apoio de IA" processRef="Process_PlataformaRF" />
    <bpmn:textAnnotation id="TextAn_Legenda">
      <bpmn:text>Artefatos de entrada: descricao em linguagem natural (PT-BR). Opcional: flag &#34;sugerir requisitos adicionais com IA&#34;.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAn_ArtefatosRF">
      <bpmn:text>Saida fase RF: requisitos_funcionais.json, requisitos_funcionais.md</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAn_ArtefatosUC">
      <bpmn:text>Saida fase UC: tabela_casos_de_uso.md, casos_de_uso.csv, relatorio_casos_de_uso.txt, diagrama_casos_de_uso.svg, diagrama_casos_de_uso.puml, relatorio_completo.pdf (parcial)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAn_ArtefatosUS">
      <bpmn:text>Saida fase US: user_stories.json, user_stories.md; PDF final consolida todas as etapas.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_Legenda_Start" associationDirection="None" sourceRef="StartEvent_Inicio" targetRef="TextAn_Legenda" />
    <bpmn:association id="Assoc_RF_IA" associationDirection="None" sourceRef="Activity_ExtrairRFsIA" targetRef="TextAn_ArtefatosRF" />
    <bpmn:association id="Assoc_UC_Export" associationDirection="None" sourceRef="Activity_GerarArtefatosUC" targetRef="TextAn_ArtefatosUC" />
    <bpmn:association id="Assoc_US_Final" associationDirection="None" sourceRef="Activity_ExportarConsolidado" targetRef="TextAn_ArtefatosUS" />
    <bpmn:association id="Assoc_DO_Texto" associationDirection="None" sourceRef="Activity_InformarDescricao" targetRef="DataObjectRef_Texto" />
    <bpmn:association id="Assoc_DO_RFJson" associationDirection="None" sourceRef="Activity_ExtrairRFsIA" targetRef="DataObjectRef_RFJson" />
    <bpmn:association id="Assoc_DO_RFmd" associationDirection="None" sourceRef="Activity_ExtrairRFsIA" targetRef="DataObjectRef_RFmd" />
    <bpmn:association id="Assoc_DO_UC" associationDirection="None" sourceRef="Activity_GerarArtefatosUC" targetRef="DataObjectRef_UCPack" />
    <bpmn:association id="Assoc_DO_US" associationDirection="None" sourceRef="Activity_GerarUserStoriesIA" targetRef="DataObjectRef_USPack" />
    <bpmn:association id="Assoc_DO_PDF" associationDirection="None" sourceRef="Activity_ExportarConsolidado" targetRef="DataObjectRef_PDF" />
    <bpmn:textAnnotation id="TextAn_Reset">
      <bpmn:text>Opcional a qualquer momento: acao &#34;Resetar pipeline&#34; na UI limpa estado e volta ao passo de informar descricao (nao modelado como sequencia apos o fim).</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_Reset" associationDirection="None" sourceRef="Activity_InformarDescricao" targetRef="TextAn_Reset" />
  </bpmn:collaboration>
  <bpmn:process id="Process_PlataformaRF" isExecutable="true">
    <bpmn:laneSet id="LaneSet_Principal">
      <bpmn:lane id="Lane_Usuario" name="Usuario">
        <bpmn:flowNodeRef>StartEvent_Inicio</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_InformarDescricao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_EditarRFs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_RevisarUCs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_EditarUCs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_BaixarPDF</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Fim</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_IA_RF" name="Modulo de Extracao de Requisitos (IA)">
        <bpmn:flowNodeRef>Activity_ExtrairRFsIA</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Validacao_RF" name="Modulo de Validacao de Requisitos">
        <bpmn:flowNodeRef>Activity_ExibirTabelaRF</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RF_Aprovados</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Gerador_UC" name="Gerador de Casos de Uso">
        <bpmn:flowNodeRef>Activity_ConverterRFparaUC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_DetectarRelacoesIncludeExtend</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Exportacao" name="Exportacao e Visualizacao">
        <bpmn:flowNodeRef>Activity_GerarArtefatosUC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_UC_Aprovados</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ExportarConsolidado</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_IA_US" name="Sistema de IA para User Stories">
        <bpmn:flowNodeRef>Activity_GerarUserStoriesIA</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:dataObject id="DataObject_TextoLivre" name="Descricao do sistema (texto livre, PT-BR)" />
    <bpmn:dataObject id="DataObject_RF_JSON" name="requisitos_funcionais.json" />
    <bpmn:dataObject id="DataObject_RF_MD" name="requisitos_funcionais.md" />
    <bpmn:dataObject id="DataObject_UC_Pack" name="Pacote UC: tabela MD, CSV, relatorio TXT, SVG, PlantUML" />
    <bpmn:dataObject id="DataObject_US_Pack" name="user_stories.json / user_stories.md" />
    <bpmn:dataObject id="DataObject_PDF" name="relatorio_completo.pdf" />
    <bpmn:dataObjectReference id="DataObjectRef_Texto" dataObjectRef="DataObject_TextoLivre" />
    <bpmn:dataObjectReference id="DataObjectRef_RFJson" dataObjectRef="DataObject_RF_JSON" />
    <bpmn:dataObjectReference id="DataObjectRef_RFmd" dataObjectRef="DataObject_RF_MD" />
    <bpmn:dataObjectReference id="DataObjectRef_UCPack" dataObjectRef="DataObject_UC_Pack" />
    <bpmn:dataObjectReference id="DataObjectRef_USPack" dataObjectRef="DataObject_US_Pack" />
    <bpmn:dataObjectReference id="DataObjectRef_PDF" dataObjectRef="DataObject_PDF" />
    <bpmn:startEvent id="StartEvent_Inicio" name="Inicio da analise">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Activity_InformarDescricao" name="Informar descricao livre e opcao &#34;sugerir extras IA&#34;">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_ExtrairRFsIA" name="Extrair RFs candidatos (OpenAI API)" implementation="##WebService">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Activity_ExibirTabelaRF" name="Exibir tabela editavel de RFs (incluir / excluir / editar)">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:incoming>Flow_LoopRF_Volta</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_RF_Aprovados" name="RFs validados pelo usuario?">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_LoopRF</bpmn:outgoing>
      <bpmn:outgoing>Flow_RF_OK</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_EditarRFs" name="Ajustar RFs e voltar a revisao">
      <bpmn:incoming>Flow_LoopRF</bpmn:incoming>
      <bpmn:outgoing>Flow_LoopRF_Volta</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_ConverterRFparaUC" name="Converter RFs aprovados em modelo de casos de uso">
      <bpmn:incoming>Flow_RF_OK</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_DetectarRelacoesIncludeExtend" name="Detectar relacoes include e extend (UML)">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_GerarArtefatosUC" name="Gerar tabela MD, CSV, relatorio, SVG, PlantUML e PDF parcial">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Activity_RevisarUCs" name="Revisar UCs na tabela editavel (salvar / adicionar / remover)">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:incoming>Flow_LoopUC_Volta</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_UC_Aprovados" name="UCs validados pelo usuario?">
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:outgoing>Flow_LoopUC</bpmn:outgoing>
      <bpmn:outgoing>Flow_UC_OK</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_EditarUCs" name="Editar UCs e salvar regeneracao">
      <bpmn:incoming>Flow_LoopUC</bpmn:incoming>
      <bpmn:outgoing>Flow_LoopUC_Volta</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_GerarUserStoriesIA" name="Gerar User Stories (Mike Cohn + criterios Gherkin)" implementation="##WebService">
      <bpmn:incoming>Flow_UC_OK</bpmn:incoming>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_ExportarConsolidado" name="Consolidar PDF completo e artefatos finais">
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Activity_BaixarPDF" name="Baixar PDF e revisar entregas">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_Fim" name="Fim: rastreabilidade texto para RF para UC para US">
      <bpmn:incoming>Flow_11</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Inicio" targetRef="Activity_InformarDescricao" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Activity_InformarDescricao" targetRef="Activity_ExtrairRFsIA" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Activity_ExtrairRFsIA" targetRef="Activity_ExibirTabelaRF" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Activity_ExibirTabelaRF" targetRef="Gateway_RF_Aprovados" />
    <bpmn:sequenceFlow id="Flow_LoopRF" name="Nao / revalidar" sourceRef="Gateway_RF_Aprovados" targetRef="Activity_EditarRFs" />
    <bpmn:sequenceFlow id="Flow_LoopRF_Volta" sourceRef="Activity_EditarRFs" targetRef="Activity_ExibirTabelaRF" />
    <bpmn:sequenceFlow id="Flow_RF_OK" name="Sim, validar RFs" sourceRef="Gateway_RF_Aprovados" targetRef="Activity_ConverterRFparaUC" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Activity_ConverterRFparaUC" targetRef="Activity_DetectarRelacoesIncludeExtend" />
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Activity_DetectarRelacoesIncludeExtend" targetRef="Activity_GerarArtefatosUC" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="Activity_GerarArtefatosUC" targetRef="Activity_RevisarUCs" />
    <bpmn:sequenceFlow id="Flow_08" sourceRef="Activity_RevisarUCs" targetRef="Gateway_UC_Aprovados" />
    <bpmn:sequenceFlow id="Flow_LoopUC" name="Nao / revalidar" sourceRef="Gateway_UC_Aprovados" targetRef="Activity_EditarUCs" />
    <bpmn:sequenceFlow id="Flow_LoopUC_Volta" sourceRef="Activity_EditarUCs" targetRef="Activity_RevisarUCs" />
    <bpmn:sequenceFlow id="Flow_UC_OK" name="Sim, validar UCs" sourceRef="Gateway_UC_Aprovados" targetRef="Activity_GerarUserStoriesIA" />
    <bpmn:sequenceFlow id="Flow_09" sourceRef="Activity_GerarUserStoriesIA" targetRef="Activity_ExportarConsolidado" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Activity_ExportarConsolidado" targetRef="Activity_BaixarPDF" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Activity_BaixarPDF" targetRef="EndEvent_Fim" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_PlataformaRF">
    <bpmndi:BPMNPlane id="BPMNPlane_PlataformaRF" bpmnElement="Collaboration_PlataformaRF">
      <bpmndi:BPMNShape id="Participant_Plataforma_di" bpmnElement="Participant_Plataforma" isHorizontal="true">
        <dc:Bounds x="120" y="40" width="3400" height="1180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Usuario_di" bpmnElement="Lane_Usuario" isHorizontal="true">
        <dc:Bounds x="150" y="40" width="3370" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_IA_RF_di" bpmnElement="Lane_IA_RF" isHorizontal="true">
        <dc:Bounds x="150" y="220" width="3370" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Validacao_RF_di" bpmnElement="Lane_Validacao_RF" isHorizontal="true">
        <dc:Bounds x="150" y="400" width="3370" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Gerador_UC_di" bpmnElement="Lane_Gerador_UC" isHorizontal="true">
        <dc:Bounds x="150" y="580" width="3370" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Exportacao_di" bpmnElement="Lane_Exportacao" isHorizontal="true">
        <dc:Bounds x="150" y="760" width="3370" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_IA_US_di" bpmnElement="Lane_IA_US" isHorizontal="true">
        <dc:Bounds x="150" y="940" width="3370" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_Inicio_di" bpmnElement="StartEvent_Inicio">
