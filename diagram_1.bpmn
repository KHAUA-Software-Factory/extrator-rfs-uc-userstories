<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_MacroIA" targetNamespace="http://mestrado.exu/macro-ia" exporter="Camunda Modeler" exporterVersion="5.46.1" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.21.0">
  <bpmn:collaboration id="Collaboration_MacroIA">
    <bpmn:participant id="Participant_ProcessoIA" name="Macroprocesso de engenharia de requisitos apoiado por IA" processRef="Process_MacroIA" />
    <bpmn:participant id="Participant_OpenAI" name="OpenAI API (servico externo de IA)" processRef="Process_OpenAI" />
    <bpmn:messageFlow id="MF_RF_REQ" name="prompt com descricao" sourceRef="Sub_ExtrairRFsIA" targetRef="AI_ExtrairRFs" />
    <bpmn:messageFlow id="MF_RF_RES" name="RFs&#10;estruturados" sourceRef="AI_ExtrairRFs" targetRef="Sub_ExtrairRFsIA" />
    <bpmn:messageFlow id="MF_UC_REQ" name="prompt com RFs validados" sourceRef="Sub_GerarUCsIA" targetRef="AI_GerarUCs" />
    <bpmn:messageFlow id="MF_UC_RES" name="UCs estruturados" sourceRef="AI_GerarUCs" targetRef="Sub_GerarUCsIA" />
    <bpmn:messageFlow id="MF_US_REQ" name="prompt com PlantUML validado" sourceRef="Sub_GerarUSIA" targetRef="AI_GerarUS" />
    <bpmn:messageFlow id="MF_US_RES" name="User Stories estruturadas" sourceRef="AI_GerarUS" targetRef="Sub_GerarUSIA" />
    <bpmn:textAnnotation id="TA_Escopo">
      <bpmn:text>Escopo: autenticação, hospedagem e controle de acesso são pré-condições técnicas do protótipo online para avaliacao; o BPMN modela o processo conceitual de apoio de IA.</bpmn:text>
    </bpmn:textAnnotation>
  </bpmn:collaboration>
  <bpmn:process id="Process_MacroIA" isExecutable="false">
    <bpmn:laneSet id="LaneSet_MacroIA">
      <bpmn:lane id="Lane_Stakeholders" name="Usuario / stakeholders">
        <bpmn:flowNodeRef>Start_Processo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistrarBrainstorm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_DescricaoSuficiente</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ComplementarDescricao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RevisarRFs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_RFsAprovados</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AjustarRFs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RevisarUCs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_UCsAprovados</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AjustarUCs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RevisarDiagrama</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_DiagramaAprovado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AjustarDiagrama</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RevisarUS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_USAprovadas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AjustarUS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FinalizarAnalise</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Processo</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Aplicacao" name="Aplicacao de apoio a engenharia de requisitos">
        <bpmn:flowNodeRef>Task_GerarDiagrama</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GerarPDF</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Sub_ExtrairRFsIA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Sub_GerarUCsIA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Sub_GerarUSIA</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Processo" name="Inicio da analise de requisitos">
      <bpmn:outgoing>F001</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_RegistrarBrainstorm" name="Registrar brainstorm e descricao livre">
      <bpmn:incoming>F001</bpmn:incoming>
      <bpmn:incoming>F004</bpmn:incoming>
      <bpmn:outgoing>F002</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_DescricaoSuficiente" name="Descricao suficiente?">
      <bpmn:incoming>F002</bpmn:incoming>
      <bpmn:outgoing>F003</bpmn:outgoing>
      <bpmn:outgoing>F005</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ComplementarDescricao" name="Complementar descricao do sistema">
      <bpmn:incoming>F003</bpmn:incoming>
      <bpmn:outgoing>F004</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_RevisarRFs" name="Revisar e validar requisitos funcionais">
      <bpmn:incoming>F006</bpmn:incoming>
      <bpmn:outgoing>F007</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_RFsAprovados" name="RFs aprovados?">
      <bpmn:incoming>F007</bpmn:incoming>
      <bpmn:outgoing>F008</bpmn:outgoing>
      <bpmn:outgoing>F010</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_AjustarRFs" name="Ajustar descricao ou RFs">
      <bpmn:incoming>F008</bpmn:incoming>
      <bpmn:outgoing>F009</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_RevisarUCs" name="Revisar e validar casos de uso">
      <bpmn:incoming>F011</bpmn:incoming>
      <bpmn:outgoing>F012</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_UCsAprovados" name="UCs aprovados?">
      <bpmn:incoming>F012</bpmn:incoming>
      <bpmn:outgoing>F013</bpmn:outgoing>
      <bpmn:outgoing>F015</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_AjustarUCs" name="Ajustar UCs, atores ou relacoes">
      <bpmn:incoming>F013</bpmn:incoming>
      <bpmn:outgoing>F014</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_GerarDiagrama" name="Gerar diagrama de casos de uso" implementation="##WebService">
      <bpmn:incoming>F015</bpmn:incoming>
      <bpmn:incoming>F019</bpmn:incoming>
      <bpmn:outgoing>F016</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_RevisarDiagrama" name="Revisar e validar diagrama">
      <bpmn:incoming>F016</bpmn:incoming>
      <bpmn:outgoing>F017</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_DiagramaAprovado" name="Diagrama aprovado?">
      <bpmn:incoming>F017</bpmn:incoming>
      <bpmn:outgoing>F018</bpmn:outgoing>
      <bpmn:outgoing>F020</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_AjustarDiagrama" name="Ajustar diagrama ou UCs">
      <bpmn:incoming>F018</bpmn:incoming>
      <bpmn:outgoing>F019</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_RevisarUS" name="Revisar User Stories e criterios">
      <bpmn:incoming>F021</bpmn:incoming>
      <bpmn:outgoing>F022</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_USAprovadas" name="User Stories aprovadas?">
      <bpmn:incoming>F022</bpmn:incoming>
      <bpmn:outgoing>F023</bpmn:outgoing>
      <bpmn:outgoing>F025</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_AjustarUS" name="Regenerar ou ajustar base das User Stories">
      <bpmn:incoming>F023</bpmn:incoming>
      <bpmn:outgoing>F024</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_GerarPDF" name="Gerar relatorio PDF para download" implementation="##WebService">
      <bpmn:incoming>F025</bpmn:incoming>
      <bpmn:outgoing>F026</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_FinalizarAnalise" name="Finalizar extracao">
      <bpmn:incoming>F026</bpmn:incoming>
      <bpmn:outgoing>F027</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_Processo" name="Analise concluida">
      <bpmn:incoming>F027</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:subProcess id="Sub_ExtrairRFsIA" name="Subprocesso: extrair RFs com IA&#10;(descricao -&#62; requisitos funcionais)">
      <bpmn:incoming>F005</bpmn:incoming>
      <bpmn:incoming>F009</bpmn:incoming>
      <bpmn:outgoing>F006</bpmn:outgoing>
    </bpmn:subProcess>
    <bpmn:subProcess id="Sub_GerarUCsIA" name="Subprocesso: gerar UCs com IA&#10;(RFs validados -&#62; casos de uso)">
      <bpmn:incoming>F010</bpmn:incoming>
      <bpmn:incoming>F014</bpmn:incoming>
      <bpmn:outgoing>F011</bpmn:outgoing>
    </bpmn:subProcess>
    <bpmn:subProcess id="Sub_GerarUSIA" name="Subprocesso: gerar User Stories com IA&#10;(PlantUML validado -&#62; User Stories)">
      <bpmn:incoming>F020</bpmn:incoming>
      <bpmn:incoming>F024</bpmn:incoming>
      <bpmn:outgoing>F021</bpmn:outgoing>
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="F001" sourceRef="Start_Processo" targetRef="Task_RegistrarBrainstorm" />
    <bpmn:sequenceFlow id="F004" sourceRef="Task_ComplementarDescricao" targetRef="Task_RegistrarBrainstorm" />
    <bpmn:sequenceFlow id="F002" sourceRef="Task_RegistrarBrainstorm" targetRef="GW_DescricaoSuficiente" />
    <bpmn:sequenceFlow id="F003" name="Nao" sourceRef="GW_DescricaoSuficiente" targetRef="Task_ComplementarDescricao" />
    <bpmn:sequenceFlow id="F005" name="Sim" sourceRef="GW_DescricaoSuficiente" targetRef="Sub_ExtrairRFsIA" />
    <bpmn:sequenceFlow id="F006" sourceRef="Sub_ExtrairRFsIA" targetRef="Task_RevisarRFs" />
    <bpmn:sequenceFlow id="F007" sourceRef="Task_RevisarRFs" targetRef="GW_RFsAprovados" />
    <bpmn:sequenceFlow id="F008" name="Nao" sourceRef="GW_RFsAprovados" targetRef="Task_AjustarRFs" />
    <bpmn:sequenceFlow id="F010" name="Sim" sourceRef="GW_RFsAprovados" targetRef="Sub_GerarUCsIA" />
    <bpmn:sequenceFlow id="F009" sourceRef="Task_AjustarRFs" targetRef="Sub_ExtrairRFsIA" />
    <bpmn:sequenceFlow id="F011" sourceRef="Sub_GerarUCsIA" targetRef="Task_RevisarUCs" />
    <bpmn:sequenceFlow id="F012" sourceRef="Task_RevisarUCs" targetRef="GW_UCsAprovados" />
    <bpmn:sequenceFlow id="F013" name="Nao" sourceRef="GW_UCsAprovados" targetRef="Task_AjustarUCs" />
    <bpmn:sequenceFlow id="F015" name="Sim" sourceRef="GW_UCsAprovados" targetRef="Task_GerarDiagrama" />
    <bpmn:sequenceFlow id="F014" sourceRef="Task_AjustarUCs" targetRef="Sub_GerarUCsIA" />
    <bpmn:sequenceFlow id="F019" sourceRef="Task_AjustarDiagrama" targetRef="Task_GerarDiagrama" />
    <bpmn:sequenceFlow id="F016" sourceRef="Task_GerarDiagrama" targetRef="Task_RevisarDiagrama" />
    <bpmn:sequenceFlow id="F017" sourceRef="Task_RevisarDiagrama" targetRef="GW_DiagramaAprovado" />
    <bpmn:sequenceFlow id="F018" name="Nao" sourceRef="GW_DiagramaAprovado" targetRef="Task_AjustarDiagrama" />
    <bpmn:sequenceFlow id="F020" name="Sim" sourceRef="GW_DiagramaAprovado" targetRef="Sub_GerarUSIA" />
    <bpmn:sequenceFlow id="F021" sourceRef="Sub_GerarUSIA" targetRef="Task_RevisarUS" />
    <bpmn:sequenceFlow id="F022" sourceRef="Task_RevisarUS" targetRef="GW_USAprovadas" />
    <bpmn:sequenceFlow id="F023" name="Nao" sourceRef="GW_USAprovadas" targetRef="Task_AjustarUS" />
    <bpmn:sequenceFlow id="F025" name="Sim" sourceRef="GW_USAprovadas" targetRef="Task_GerarPDF" />
    <bpmn:sequenceFlow id="F024" sourceRef="Task_AjustarUS" targetRef="Sub_GerarUSIA" />
    <bpmn:sequenceFlow id="F026" sourceRef="Task_GerarPDF" targetRef="Task_FinalizarAnalise" />
    <bpmn:sequenceFlow id="F027" sourceRef="Task_FinalizarAnalise" targetRef="End_Processo" />
  </bpmn:process>
  <bpmn:process id="Process_OpenAI" isExecutable="false">
    <bpmn:serviceTask id="AI_ExtrairRFs" name="OpenAI: extrair RFs" implementation="##WebService" />
    <bpmn:serviceTask id="AI_GerarUCs" name="OpenAI: gerar UCs" implementation="##WebService" />
    <bpmn:serviceTask id="AI_GerarUS" name="OpenAI: gerar User Stories" implementation="##WebService" />
  </bpmn:process>
